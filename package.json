{
  "name": "@systynlabs/vaultnuban",
  "version": "0.1.0",
  "description": "Official TypeScript/Node SDK for the VaultNUBAN virtual account API",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Systyn-Labs/vaultnuban-js.git"
  },
  "bugs": "https://github.com/Systyn-Labs/vaultnuban-js/issues",
  "homepage": "https://github.com/Systyn-Labs/vaultnuban-js#readme",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./webhooks": {
      "types": "./dist/webhooks.d.ts",
      "import": "./dist/webhooks.js",
      "require": "./dist/webhooks.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts src/webhooks.ts --format esm,cjs --dts --clean",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "npm run build && changeset publish",
    "prepublishOnly": "npm run typecheck && npm run lint && npm run test && npm run build"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.0",
    "eslint": "^10.6.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.62.1",
    "vitest": "^1.6.0"
  },
  "keywords": [
    "vaultnuban",
    "nuban",
    "virtual-account",
    "nomba",
    "payments",
    "nigeria",
    "fintech"
  ]
}
